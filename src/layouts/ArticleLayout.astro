---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import QRCodeModal from '@components/QRCodeModal.astro';
import SEO from '@components/SEO.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  breadcrumbs: { label: string; href?: string }[];
  faqSchema?: { q: string; a: string }[];
  schema?: Record<string, unknown>;
}

const { title, description, breadcrumbs, faqSchema, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO {title} {description} {schema} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <article class="pt-16 pb-24 md:pt-24 md:pb-32 px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <Breadcrumb items={breadcrumbs} />
          <div class="article-content">
            <slot />
          </div>
        </div>
      </article>
    </main>
    <Footer />
    <QRCodeModal />

    {faqSchema && faqSchema.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqSchema.map(f => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      })} />
    )}
  </body>
</html>
