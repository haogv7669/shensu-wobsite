---
interface Props {
  steps: { title: string; body: string }[];
  dark?: boolean;
}

const { steps, dark = false } = Astro.props;
---

<ol class="relative flex flex-col sm:flex-row gap-4 sm:gap-0">
  {steps.map((s, i) => (
    <li class="flex-1 relative flex sm:block gap-4">
      <div class="flex flex-col items-center shrink-0 sm:mb-4">
        <span class={`w-8 h-8 flex items-center justify-center rounded-full text-xs font-semibold ${dark ? 'bg-accent text-white' : 'bg-primary text-white'}`}>
          {i + 1}
        </span>
        {i < steps.length - 1 && (
          <div class={`w-px flex-1 sm:hidden mt-1 ${dark ? 'bg-white/15' : 'bg-border'}`} />
        )}
      </div>
      <div class="pb-6 sm:pb-0 sm:text-center sm:px-2">
        <h4 class={`text-sm font-semibold ${dark ? 'text-white' : 'text-primary'}`}>{s.title}</h4>
        <p class={`mt-1 text-xs leading-relaxed ${dark ? 'text-white/65' : 'text-text-muted'}`}>{s.body}</p>
      </div>
      {i < steps.length - 1 && (
        <div class={`hidden sm:block absolute top-4 h-px ${dark ? 'bg-white/15' : 'bg-border'}`} style={`left: calc(${(i + 0.5) * (100 / steps.length)}% + 1rem); width: calc(${100 / steps.length}% - 2rem);`} />
      )}
    </li>
  ))}
</ol>
