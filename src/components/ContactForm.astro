<form id="contact-form" class="space-y-4" novalidate>
  <div>
    <label class="block text-xs font-medium text-text mb-1.5">店铺平台 <span class="text-red-500">*</span></label>
    <select name="platform" required class="w-full px-3 py-2.5 text-sm border border-border rounded focus:outline-none focus:border-primary bg-white">
      <option value="" disabled selected>请选择</option>
      <option value="taobao">淘宝</option>
      <option value="tmall">天猫</option>
      <option value="pdd">拼多多</option>
      <option value="douyin">抖音</option>
      <option value="other">其他</option>
    </select>
  </div>

  <div>
    <label class="block text-xs font-medium text-text mb-1.5">违规类型 <span class="text-red-500">*</span></label>
    <select name="violation" required class="w-full px-3 py-2.5 text-sm border border-border rounded focus:outline-none focus:border-primary bg-white">
      <option value="" disabled selected>请选择</option>
      <option value="shoujia">售假</option>
      <option value="ip">知识产权</option>
      <option value="xuni">虚假交易</option>
      <option value="anquan">危及交易安全</option>
      <option value="other">其他 / 不确定</option>
    </select>
  </div>

  <div>
    <label class="block text-xs font-medium text-text mb-1.5">是否首次申诉 <span class="text-red-500">*</span></label>
    <div class="flex gap-6">
      <label class="flex items-center gap-1.5 text-sm text-text-muted cursor-pointer">
        <input type="radio" name="firstAppeal" value="yes" required class="accent-primary" /> 是
      </label>
      <label class="flex items-center gap-1.5 text-sm text-text-muted cursor-pointer">
        <input type="radio" name="firstAppeal" value="no" required class="accent-primary" /> 否（之前申诉过）
      </label>
    </div>
  </div>

  <div>
    <label class="block text-xs font-medium text-text mb-1.5">现有材料（可多选）</label>
    <div class="grid grid-cols-2 gap-2">
      {['授权书', '发票', '采购/进货记录', '物流记录', '对公流水', '都没有'].map(m => (
        <label class="flex items-center gap-1.5 text-sm text-text-muted cursor-pointer">
          <input type="checkbox" name="materials" value={m} class="accent-primary rounded" /> {m}
        </label>
      ))}
    </div>
  </div>

  <div>
    <label class="block text-xs font-medium text-text mb-1.5">联系方式（微信号 / 手机号）<span class="text-red-500">*</span></label>
    <input type="text" name="contact" required placeholder="方便我们 2 小时内反馈" class="w-full px-3 py-2.5 text-sm border border-border rounded focus:outline-none focus:border-primary" />
  </div>

  <div>
    <label class="block text-xs font-medium text-text mb-1.5">简述情况（可选）</label>
    <textarea name="description" rows="2" placeholder="处罚类型、什么时间收到的、有没有申诉入口" class="w-full px-3 py-2.5 text-sm border border-border rounded focus:outline-none focus:border-primary resize-none"></textarea>
  </div>

  <button type="submit" class="w-full py-2.5 text-sm font-medium text-white bg-primary hover:bg-primary-light rounded transition-colors">
    提交 · 免费初筛
  </button>
</form>

<div id="form-success" class="hidden text-center py-8">
  <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center rounded-full bg-green-100 text-green-600">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
  </div>
  <p class="text-sm font-semibold text-primary">已收到，初筛不收费</p>
  <p class="mt-1 text-xs text-text-muted">2 小时内微信反馈</p>
  <div class="mt-5 w-40 h-40 mx-auto bg-surface-alt rounded flex items-center justify-center">
    <img src="/images/qrcode.jpg" alt="微信二维码" class="w-full h-full object-contain rounded" loading="lazy" />
  </div>
  <p class="mt-3 text-xs text-text-muted">扫码添加微信，确保消息不遗漏</p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    form.classList.add('hidden');
    success.classList.remove('hidden');
  });
</script>
