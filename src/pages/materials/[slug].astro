---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('materials');
  return items.map(item => ({ params: { slug: item.id } }));
}

const { slug } = Astro.params;
const items = await getCollection('materials');
const item = items.find(i => i.id === slug);

if (!item) return Astro.redirect('/404');

const { Content } = await render(item);
const faq = item.data.faq || [];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: item.data.title,
  description: item.data.description,
  author: { '@type': 'Organization', name: '壹号申诉' },
};
---

<ArticleLayout
  title={`${item.data.title} — 壹号申诉`}
  description={item.data.description}
  keywords="淘宝申诉,申诉材料,电商合规"
  breadcrumbs={[
    { label: '首页', href: '/' },
    { label: '材料专题', href: '/materials/shouquan-lian/' },
    { label: item.data.title },
  ]}
  faqSchema={faq}
  articleSchema={articleSchema}
>
  <h1 class="text-xl md:text-2xl font-semibold text-primary leading-snug mb-6">{item.data.title}</h1>
  <Content />
</ArticleLayout>
