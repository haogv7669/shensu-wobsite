---
import BaseLayout from '@layouts/BaseLayout.astro';

const examples = [
  { shopType: '淘宝C店', violation: '售假误判', gap: '授权链中间环节缺失，品牌方→代理商→经销商链路不完整', fix: '绕开缺失环节，用连续进货凭证+付款记录+物流单据重建证据闭环', status: '已完结' },
  { shopType: '天猫旗舰店', violation: '知识产权投诉', gap: '被同行以商标权人身份投诉，授权书已过期', fix: '以在先使用+平行进口方向整理答辩材料，用进货发票+正品实拍替代过期授权书', status: '已完结' },
  { shopType: '淘宝C店', violation: '不当使用他人权利', gap: '商品描述中引用品牌名被判不当使用，商品本身为正品', fix: '提供进货发票+正品实拍+描述修改对照，证明描述为客观陈述', status: '已完结' },
  { shopType: '天猫旗舰店', violation: '虚假交易', gap: '真实订单被误识别为虚假交易，订单分散导致系统误判', fix: '逐笔整理物流凭证+聊天记录+收款记录，证明交易真实性', status: '已完结' },
  { shopType: '淘宝企业店', violation: '危及交易安全', gap: '商品被判定为异常，支付宝功能受限', fix: '梳理商品来源+进货凭证+质检报告，线下到访阿里沟通', status: '已完结' },
  { shopType: '淘宝C店', violation: '账期延长', gap: '回款周期被延长至90天，资金压力大', fix: '提供连续6个月交易记录+买家确认记录，申请恢复标准账期', status: '处理中' },
];
---

<BaseLayout title="脱敏案例展示 — 壹号申诉" description="壹号申诉真实脱敏案例展示。涵盖售假误判、知识产权投诉、虚假交易等场景。不承诺结果，仅供参考。">
  <section class="pt-20 pb-24 md:pt-28 md:pb-32 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-2xl md:text-3xl font-semibold text-primary mb-3">脱敏案例展示</h1>
        <p class="text-sm text-text-muted max-w-lg mx-auto">真实案例，脱敏处理。所有可识别信息均已隐去。</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
        <button data-filter="all" class="filter-btn px-3 py-1.5 text-xs rounded border border-primary text-white bg-primary">全部</button>
        {['售假误判','知识产权投诉','不当使用他人权利','虚假交易','危及交易安全','账期延长'].map(t => (
          <button data-filter={t} class="filter-btn px-3 py-1.5 text-xs rounded border border-border text-text-muted hover:border-primary hover:text-primary transition-colors bg-white">{t}</button>
        ))}
      </div>

      <div class="space-y-4" id="case-list">
        {examples.map(c => (
          <div class="case-item bg-white rounded border border-border p-5 md:p-6" data-category={c.violation}>
            <div class="flex flex-wrap items-center gap-2.5 mb-3">
              <span class="text-[11px] font-medium text-accent bg-accent/5 px-2 py-0.5 rounded">{c.violation}</span>
              <span class="text-[11px] text-text-light">{c.shopType}</span>
              <span class="text-[11px] font-medium text-primary bg-primary/5 px-2 py-0.5 rounded">{c.status}</span>
            </div>
            <div class="text-sm space-y-2">
              <p><span class="font-semibold text-primary">材料缺口：</span><span class="text-text-muted">{c.gap}</span></p>
              <p><span class="font-semibold text-primary">补强方向：</span><span class="text-text-muted">{c.fix}</span></p>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-10 text-xs text-text-light text-center">以上案例均已脱敏处理，仅为过往经验展示，不做结果承诺。每个案件具体情况不同，请以实际评估为准。</p>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => { b.className = b.className.replace(/bg-primary text-white/, 'bg-white text-text-muted border-border'); b.classList.add('border'); });
      (btn as HTMLElement).className = (btn as HTMLElement).className.replace(/bg-white text-text-muted border-border/, 'bg-primary text-white');
      const filter = (btn as HTMLElement).dataset.filter;
      document.querySelectorAll('.case-item').forEach(item => {
        (item as HTMLElement).style.display = (filter === 'all' || (item as HTMLElement).dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
