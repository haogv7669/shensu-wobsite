<svg xmlns="http://www.w3.org/2000/svg" width="600" height="300" viewBox="0 0 600 300">
  <rect width="600" height="300" fill="#f8fafc"/>
  <!-- simplified campus style map -->
  <rect x="100" y="50" width="400" height="200" rx="8" fill="#e2e8f0" stroke="#cbd5e1" stroke-width="2"/>
  <rect x="200" y="100" width="60" height="100" rx="4" fill="#1a2744" opacity="0.15"/>
  <rect x="280" y="120" width="80" height="50" rx="4" fill="#1a2744" opacity="0.1"/>
  <rect x="380" y="100" width="60" height="60" rx="4" fill="#1a2744" opacity="0.1"/>
  <circle cx="300" cy="200" r="4" fill="#c5923c"/>
  <text x="300" y="220" text-anchor="middle" fill="#c5923c" font-size="9" font-family="sans-serif">阿里西溪园区</text>
  <text x="300" y="275" text-anchor="middle" fill="#94a3b8" font-size="10" font-family="sans-serif">杭州律师团队步行可达</text>
</svg>
